  "content": {
    "blog": [
      {
        "id": "blog-tradition-italian-cuisine",
        "slug": "tradition-of-italian-cuisine",
        "status": "published",
        "data": {
          "title": "Die Tradition der italienischen Küche im Schwarzwald",
          "excerpt": "Seit Generationen bringen wir die Aromen Italiens in den Schwarzwald. Entdecken Sie die Geschichte unseres Familienrestaurants.",
          "content": [
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Unsere Reise begann in der sonnigen Region Apuliens, wo die Familie Marcucci seit Generationen die Kunst der italienischen Küche pflegt. Heute teilen wir diese Leidenschaft mit unseren Gästen in Hinterzarten." }] },
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Jedes Gericht auf unserer Speisekarte erzählt eine Geschichte – von der Holzofen-Pizza mit knusprigem Boden bis zur hausgemachten Pasta, die nach traditionellen Familienrezepten zubereitet wird." }] },
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Was unsere Küche besonders macht, ist die Kombination aus authentischen italienischen Rezepten und den frischen Zutaten aus der Region. Unsere Gäste schätzen diese Verbindung von italienischer Tradition und Schwarzwälder Gastfreundschaft." }] }
          ]
        },
        "bylines": [{ "byline": "byline-editorial" }]
      },
      {
        "id": "blog-wood-fired-pizza",
        "slug": "art-of-wood-fired-pizza",
        "status": "published",
        "data": {
          "title": "Die Kunst der Holzofen-Pizza",
          "excerpt": "Was macht eine perfekte Pizza aus? Bei uns beginnt es mit dem Holzofen und endet mit den frischesten Zutaten.",
          "content": [
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Eine authentische italienische Pizza lebt von drei Dingen: dem Teig, dem Ofen und den Zutaten. Bei uns im Ristorante Leonardo da Vinci wird jede Pizza mit Sorgfalt zubereitet." }] },
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Unser Holzofen verleiht jeder Pizza das unverwechselbare Aroma, das nur durch die perfekte Hitze und den Rauch entsteht. Von der klassischen Margherita bis zur kreativen Pizza Burrata mit Kirschtomaten und Rucola." }] },
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Besonders stolz sind wir auf unsere glutenfreien Pizzen, die bei unseren Gästen grossen Anklang finden – ganz ohne Kompromisse beim Geschmack." }] }
          ]
        },
        "bylines": [{ "byline": "byline-editorial" }]
      },
      {
        "id": "blog-vegetarian-delights",
        "slug": "vegetarian-delights",
        "status": "published",
        "data": {
          "title": "Vegetarische Genüsse: Mehr als nur Beilage",
          "excerpt": "Unsere vegetarischen Gerichte sind alles andere als langweilig. Entdecken Sie die Vielfalt der italienischen Gemüseküche.",
          "content": [
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Die italienische Küche ist reich an vegetarischen Schätzen. Von der Bruschetta Calabrese mit Tomaten, Rucola und Parmesan bis zur Insalata con Verdure e Ricotta." }] },
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Unsere Gäste schätzen die Vielfalt unseres vegetarischen Angebots, das weit über die klassische Margherita hinausgeht. Probieren Sie unsere Pizza alle Verdure Grigliate mit gegrilltem Gemüse." }] },
            { "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Auch für vegane und glutenfreie Ernährung haben wir passende Optionen – sprechen Sie unser Team einfach an." }] }
          ]
        },
        "bylines": [{ "byline": "byline-editorial" }]
      }
    ],
