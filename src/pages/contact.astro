---
import Base from "../layouts/Base.astro";
---

<Base title="Contact – Ristorante Leonardo da Vinci Hinterzarten" description="Get in touch with Ristorante Leonardo da Vinci in Hinterzarten. Find our address, phone, email, and opening hours. Reserve your table today.">
  <div class="page-header">
    <div class="container">
      <h1>Contact & Location</h1>
      <p>Wir freuen uns auf Sie</p>
    </div>
  </div>

  <section style="padding: 4rem 0;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 3rem;">
        <div>
          <h2 style="font-size: 1.6rem; margin-bottom: 1.5rem; color: var(--color-accent);">Besuchen Sie uns</h2>
          <div style="margin-bottom: 1.5rem;">
            <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Adresse</h3>
            <p style="color: var(--color-muted);">Rathausstraße 1<br />79856 Hinterzarten<br />Germany</p>
          </div>
          <div style="margin-bottom: 1.5rem;">
            <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Telefon</h3>
            <p><a href="tel:+497652982382">+49 7652 982382</a></p>
          </div>
          <div style="margin-bottom: 1.5rem;">
            <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Email</h3>
            <p><a href="mailto:info@ristorante-leonardo-da-vinci.de">info@ristorante-leonardo-da-vinci.de</a></p>
          </div>
          <div style="margin-bottom: 1.5rem;">
            <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Inhaber</h3>
            <p style="color: var(--color-muted);">Giulio Marcucci</p>
          </div>
          <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="https://www.google.com/maps/search/?api=1&query=Rathausstraße 1, 79856 Hinterzarten" target="_blank" class="btn">Google Maps &rarr;</a>
            <a href="tel:+497652982382" class="btn btn-outline">Anrufen</a>
          </div>
        </div>
        <div>
          <h2 style="font-size: 1.6rem; margin-bottom: 1.5rem; color: var(--color-accent);">Öffnungszeiten</h2>
          <table style="width: 100%; border-collapse: collapse;">
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 0; font-weight: 600;">Montag</td>
              <td style="padding: 0.75rem 0; text-align: right; color: var(--color-muted);">12:00–14:00 & 17:00–21:00</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 0; font-weight: 600;">Dienstag</td>
              <td style="padding: 0.75rem 0; text-align: right; color: var(--color-muted);">12:00–14:00 & 17:00–21:00</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 0; font-weight: 600;">Mittwoch</td>
              <td style="padding: 0.75rem 0; text-align: right; color: #c0392b;">Geschlossen</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 0; font-weight: 600;">Donnerstag</td>
              <td style="padding: 0.75rem 0; text-align: right; color: #c0392b;">Geschlossen</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 0; font-weight: 600;">Freitag</td>
              <td style="padding: 0.75rem 0; text-align: right; color: var(--color-muted);">12:00–14:00 & 17:00–21:00</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 0; font-weight: 600;">Samstag</td>
              <td style="padding: 0.75rem 0; text-align: right; color: var(--color-muted);">12:00–14:00 & 17:00–21:00</td>
            </tr>
            <tr>
              <td style="padding: 0.75rem 0; font-weight: 600;">Sonntag</td>
              <td style="padding: 0.75rem 0; text-align: right; color: var(--color-muted);">12:00–14:00 & 17:00–21:00</td>
            </tr>
          </table>

          <h2 style="font-size: 1.6rem; margin: 2rem 0 1.5rem; color: var(--color-accent);">Zahlungsmöglichkeiten</h2>
          <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
            <span style="background: var(--color-surface); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem;">Bar</span>
            <span style="background: var(--color-surface); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem;">Mastercard</span>
            <span style="background: var(--color-surface); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem;">VISA</span>
            <span style="background: var(--color-surface); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem;">Maestro</span>
            <span style="background: var(--color-surface); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem;">EC-Karte</span>
            <span style="background: var(--color-surface); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.9rem;">Kontaktlos</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
