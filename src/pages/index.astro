---
import Base from "../layouts/Base.astro";
---

<Base title="Ristorante Leonardo da Vinci – Authentic Italian Cuisine in Hinterzarten" description="Experience authentic Italian cuisine at Ristorante Leonardo da Vinci in Hinterzarten, Black Forest. Wood-fired pizza, homemade pasta, and warm hospitality. Book your table today.">
  <section style="min-height: 85vh; display: flex; align-items: center; justify-content: center; text-align: center; background: linear-gradient(135deg, var(--color-dark) 0%, #1a1512 100%); color: #fff; padding: 2rem;">
    <div class="container">
      <p style="font-family: var(--font-display); font-style: italic; color: var(--color-gold); font-size: 1.2rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1rem;">Ristorante Pizzeria</p>
      <h1 style="font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 600; line-height: 1.1; margin-bottom: 1rem; letter-spacing: 0.02em;">
        Leonardo <span style="color: var(--color-gold);">da Vinci</span>
      </h1>
      <p style="font-size: clamp(1rem, 2vw, 1.3rem); color: rgba(255,255,255,0.75); max-width: 600px; margin: 0 auto 2.5rem; font-weight: 300;">
        Authentic Italian cuisine in the heart of the Black Forest. Wood-fired pizza, homemade pasta, and Mediterranean traditions passed down through generations.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/menu" class="btn">Unsere Speisekarte</a>
        <a href="/contact" class="btn btn-outline">Reservieren</a>
      </div>
      <div style="display: flex; gap: 2rem; justify-content: center; margin-top: 3rem; flex-wrap: wrap;">
        <div>
          <div style="font-size: 2rem; font-family: var(--font-display); color: var(--color-gold); font-weight: 700;">4.5</div>
          <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">Google Bewertung</div>
        </div>
        <div>
          <div style="font-size: 2rem; font-family: var(--font-display); color: var(--color-gold); font-weight: 700;">421+</div>
          <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">Bewertungen</div>
        </div>
        <div>
          <div style="font-size: 2rem; font-family: var(--font-display); color: var(--color-gold); font-weight: 700;">#1</div>
          <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">in Hinterzarten</div>
        </div>
      </div>
    </div>
  </section>

  <section style="padding: 5rem 0;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem; align-items: center;">
        <div>
          <h2 style="font-size: clamp(1.8rem, 3vw, 2.8rem); margin-bottom: 1.5rem; line-height: 1.2;">
            Willkommen im <span style="color: var(--color-accent);">Ristorante Leonardo da Vinci</span>
          </h2>
          <p style="color: var(--color-muted); margin-bottom: 1rem; font-size: 1.05rem;">
            Since opening our doors, we have been bringing the authentic flavours of Italy to the Black Forest. Our family-run restaurant combines traditional Italian recipes with the warmth of genuine hospitality.
          </p>
          <p style="color: var(--color-muted); margin-bottom: 1.5rem; font-size: 1.05rem;">
            From wood-fired pizzas to homemade pasta, every dish is crafted with care using the finest ingredients. Whether you join us for a romantic dinner or a lively family gathering, we invite you to savour the taste of Italy in Hinterzarten.
          </p>
          <a href="/menu" class="btn">Entdecken Sie unser Menu</a>
        </div>
        <div style="background: var(--color-surface); border-radius: 12px; padding: 2rem; min-height: 300px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--color-border);">
          <div style="text-align: center; color: var(--color-muted);">
            <div style="font-size: 3rem; margin-bottom: 1rem;">&#127829;</div>
            <p style="font-family: var(--font-display); font-size: 1.2rem;">Wood-Fired Pizza</p>
            <p>Homemade Pasta</p>
            <p>Mediterranean Specialties</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section style="padding: 4rem 0; background: var(--color-surface);">
    <div class="container">
      <h2 style="text-align: center; font-size: clamp(1.8rem, 3vw, 2.5rem); margin-bottom: 3rem;">Unsere Services</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem; text-align: center;">
        <div style="padding: 2rem 1rem; background: #fff; border-radius: 8px; border: 1px solid var(--color-border);">
          <div style="font-size: 2rem; margin-bottom: 0.75rem;">&#127860;</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Outdoor Seating</h3>
          <p style="font-size: 0.9rem; color: var(--color-muted);">Geniessen Sie die Schwarzwald-Luft</p>
        </div>
        <div style="padding: 2rem 1rem; background: #fff; border-radius: 8px; border: 1px solid var(--color-border);">
          <div style="font-size: 2rem; margin-bottom: 0.75rem;">&#128230;</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Takeaway</h3>
          <p style="font-size: 0.9rem; color: var(--color-muted);">Geniessen Sie zu Hause</p>
        </div>
        <div style="padding: 2rem 1rem; background: #fff; border-radius: 8px; border: 1px solid var(--color-border);">
          <div style="font-size: 2rem; margin-bottom: 0.75rem;">&#128247;</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Free WiFi</h3>
          <p style="font-size: 0.9rem; color: var(--color-muted);">Bleiben Sie verbunden</p>
        </div>
        <div style="padding: 2rem 1rem; background: #fff; border-radius: 8px; border: 1px solid var(--color-border);">
          <div style="font-size: 2rem; margin-bottom: 0.75rem;">&#128054;</div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.3rem;">Pets Welcome</h3>
          <p style="font-size: 0.9rem; color: var(--color-muted);">Ihre Tiere sind willkommen</p>
        </div>
      </div>
    </div>
  </section>

  <section style="padding: 4rem 0;">
    <div class="container" style="text-align: center;">
      <h2 style="font-size: clamp(1.5rem, 2.5vw, 2rem); margin-bottom: 1rem;">Was unsere Gäste sagen</h2>
      <p style="color: var(--color-muted); margin-bottom: 2.5rem; max-width: 500px; margin-left: auto; margin-right: auto;">Ausgezeichnete Bewertungen auf Google und TripAdvisor</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; text-align: left;">
        <div style="background: #fff; padding: 1.5rem; border-radius: 8px; border: 1px solid var(--color-border);">
          <div style="color: var(--color-gold); margin-bottom: 0.5rem;">★★★★★</div>
          <p style="font-style: italic; color: var(--color-muted); font-size: 0.95rem;">"Great authentic Italian food! The staff was very nice. Gluten free pizza and pasta available. Personally had the GF pizza and it was delicious. Great desserts too."</p>
          <p style="margin-top: 0.75rem; font-size: 0.85rem; color: var(--color-text);"><strong>Cortney M.</strong> &middot; Google Reviews</p>
        </div>
        <div style="background: #fff; padding: 1.5rem; border-radius: 8px; border: 1px solid var(--color-border);">
          <div style="color: var(--color-gold); margin-bottom: 0.5rem;">★★★★★</div>
          <p style="font-style: italic; color: var(--color-muted); font-size: 0.95rem;">"Very nice authentic Italian food. The pizzas were very nice and we bought a pasta with anchovy sauce and mozzarella. The prices were not exorbitant. Try this Italian. You won't be disappointed."</p>
          <p style="margin-top: 0.75rem; font-size: 0.85rem; color: var(--color-text);"><strong>G R.</strong> &middot; Google Reviews</p>
        </div>
        <div style="background: #fff; padding: 1.5rem; border-radius: 8px; border: 1px solid var(--color-border);">
          <div style="color: var(--color-gold); margin-bottom: 0.5rem;">★★★★★</div>
          <p style="font-style: italic; color: var(--color-muted); font-size: 0.95rem;">"Best ever!!! We enjoyed our lunch. The food is great & tasty & unique. The crew is lovely. I recommended this restaurant very much."</p>
          <p style="margin-top: 0.75rem; font-size: 0.85rem; color: var(--color-text);"><strong>Galit S.</strong> &middot; Google Reviews</p>
        </div>
      </div>
      <a href="/reviews" class="btn btn-outline" style="margin-top: 2rem;">Alle Bewertungen anzeigen</a>
    </div>
  </section>
</Base>
