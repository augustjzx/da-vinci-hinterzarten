---
import { getDinewayCollection } from "dineway";
import Base from "../layouts/Base.astro";

const { entries: galleryItems, cacheHint } = await getDinewayCollection("gallery", {
  status: "published",
});
Astro.cache.set(cacheHint);

const IMAGE_MAP = {
  "wood-fired-pizza": "/assets/da-vinci-hinterzarten/selected/gallery-7.jpg",
  "restaurant-interior": "/assets/da-vinci-hinterzarten/selected/gallery-3.jpg",
  "homemade-pasta": "/assets/da-vinci-hinterzarten/selected/gallery-14.jpg",
  "antipasti-platter": "/assets/da-vinci-hinterzarten/selected/gallery-4.jpg",
  "pizza-burrata": "/assets/da-vinci-hinterzarten/selected/gallery-5.jpg",
  "davinci-sign": "/assets/da-vinci-hinterzarten/selected/gallery-2.jpg",
  "restaurant-dining": "/assets/da-vinci-hinterzarten/selected/gallery-8.jpg",
  "branzino-dish": "/assets/da-vinci-hinterzarten/selected/gallery-9.jpg",
  "bistecca": "/assets/da-vinci-hinterzarten/selected/gallery-10.jpg",
  "tiramisu": "/assets/da-vinci-hinterzarten/selected/gallery-11.jpg",
  "restaurant-exterior": "/assets/da-vinci-hinterzarten/selected/gallery-18.jpg",
  "outdoor-terrace": "/assets/da-vinci-hinterzarten/selected/gallery-20.jpg",
};

const galleryImages = galleryItems.map((item) => ({
  src: IMAGE_MAP[item.slug] || "/assets/da-vinci-hinterzarten/selected/gallery-2.jpg",
  caption: item.data?.caption || item.data?.title || "",
}));
---

<Base title="Gallery – Ristorante Leonardo da Vinci Hinterzarten" description="Browse our gallery at Ristorante Leonardo da Vinci in Hinterzarten. See our wood-fired pizzas, homemade pasta, and the warm atmosphere of our Italian restaurant.">
  <div class="page-header">
    <div class="container">
      <h1>Gallery</h1>
      <p>Le nostre specialità</p>
    </div>
  </div>

  <section style="padding: 4rem 0;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
        {galleryImages.map(img => (
          <div style="border-radius: 8px; overflow: hidden; background: var(--color-surface); border: 1px solid var(--color-border);">
            <div style="aspect-ratio: 4/3; overflow: hidden;">
              <img src={img.src} alt={img.caption} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
            </div>
            <p style="padding: 0.75rem; font-size: 0.9rem; color: var(--color-muted);">{img.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
