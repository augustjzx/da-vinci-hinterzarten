---
import { getDinewayCollection } from "dineway";
import Base from "../layouts/Base.astro";

const { entries: menuItems, cacheHint } = await getDinewayCollection("menu", {
  status: "published",
});
Astro.cache.set(cacheHint);

const categories = ["Antipasti", "Insalate", "Primi Piatti", "Pizza", "Secondi Piatti", "Dessert"];
const categoryLabels = {
  Antipasti: "Antipasti",
  Insalate: "Insalate",
  "Primi Piatti": "Primi Piatti",
  Pizza: "Pizza",
  "Secondi Piatti": "Secondi Piatti",
  Dessert: "Dessert",
};

const grouped = {};
for (const cat of categories) {
  grouped[cat] = menuItems.filter((item) => item.data?.category === cat);
}

const ITEM_IMAGES = {
  "antipasto-misto": "/assets/da-vinci-hinterzarten/restaurant/real--177B97B.jpg",
  "vitello-tonnato": "/assets/da-vinci-hinterzarten/restaurant/real--177B97B.jpg",
  "carpaccio-di-manzo": "/assets/da-vinci-hinterzarten/restaurant/real--FCC6CC2.jpg",
  "carpaccio-di-tonno": "/assets/da-vinci-hinterzarten/restaurant/real--FF64896.jpg",
  "caprese": "/assets/da-vinci-hinterzarten/restaurant/real--1999-25.jpg",
  "bruschetta-calabrese": "/assets/da-vinci-hinterzarten/restaurant/real--1999-6F.jpg",
  "bruschetta-con-gamberi": "/assets/da-vinci-hinterzarten/restaurant/real--1999-6F.jpg",
  "scampetti-al-limone": "/assets/da-vinci-hinterzarten/restaurant/real--1999-25.jpg",
  "spaghetti-aglio-olio-peperoncini": "/assets/da-vinci-hinterzarten/restaurant/real--49639B5.jpg",
  "spaghetti-aglio-olio-coda-gamberi": "/assets/da-vinci-hinterzarten/restaurant/real--2F89D23.jpg",
  "fettuccini-gamberi-zafferano": "/assets/da-vinci-hinterzarten/restaurant/real--2F89D23.jpg",
  "fettucini-crema-tartufo": "/assets/da-vinci-hinterzarten/restaurant/real--49639B5.jpg",
  "risotto-ai-funghi-misti": "/assets/da-vinci-hinterzarten/restaurant/real--1999-4C.jpg",
  "lasagne": "/assets/da-vinci-hinterzarten/restaurant/real--1999-4C.jpg",
  "pizza-prosciutto-funghi": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-burrata": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-leonardo-da-vinci": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-schwarzwald": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-frutti-di-mare": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-tonnato-bianca": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-toto": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-parmigiana": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "pizza-marco-massi": "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "bistecca-alla-pizzaiola": "/assets/da-vinci-hinterzarten/restaurant/real--FCC6CC2.jpg",
  "bistecca-gorgonzola": "/assets/da-vinci-hinterzarten/restaurant/real--FCC6CC2.jpg",
  "tagliata-di-manzo": "/assets/da-vinci-hinterzarten/restaurant/real--FCC6CC2.jpg",
  "filetto-al-tartufo": "/assets/da-vinci-hinterzarten/restaurant/real--FCC6CC2.jpg",
  "filetto-pepe-verde": "/assets/da-vinci-hinterzarten/restaurant/real--FCC6CC2.jpg",
  "carre-agnello-erbe-aromatiche": "/assets/da-vinci-hinterzarten/restaurant/real--C956B77.jpg",
  "gamberi-alla-griglia": "/assets/da-vinci-hinterzarten/restaurant/real--FF64896.jpg",
  "grigliata-di-pesce": "/assets/da-vinci-hinterzarten/restaurant/real--A8FC863.jpg",
  "filetto-branzino-romana": "/assets/da-vinci-hinterzarten/restaurant/real--A8FC863.jpg",
  "tiramisu": "/assets/da-vinci-hinterzarten/restaurant/real--5C93E48.jpg",
  "panna-cotta": "/assets/da-vinci-hinterzarten/restaurant/real--5C93E48.jpg",
  "semifreddo-torroncino": "/assets/da-vinci-hinterzarten/restaurant/real--6765377.jpg",
  "gemischtes-eis": "/assets/da-vinci-hinterzarten/restaurant/real--6765377.jpg",
};
const CATEGORY_IMAGES = {
  Antipasti: "/assets/da-vinci-hinterzarten/restaurant/real--177B97B.jpg",
  Insalate: "/assets/da-vinci-hinterzarten/restaurant/real--1999-25.jpg",
  "Primi Piatti": "/assets/da-vinci-hinterzarten/restaurant/real--49639B5.jpg",
  Pizza: "/assets/da-vinci-hinterzarten/restaurant/real--5B991C9.jpg",
  "Secondi Piatti": "/assets/da-vinci-hinterzarten/restaurant/real--FCC6CC2.jpg",
  Dessert: "/assets/da-vinci-hinterzarten/restaurant/real--5C93E48.jpg",
};
---

<Base title="Menu – Ristorante Leonardo da Vinci Hinterzarten" description="Browse our authentic Italian menu at Ristorante Leonardo da Vinci in Hinterzarten. Wood-fired pizza, homemade pasta, fresh salads, and grilled specialties.">
  <div class="page-header">
    <div class="container">
      <h1>Unsere Speisekarte</h1>
      <p>Authentische italienische Küche im Schwarzwald</p>
    </div>
  </div>

  <section style="padding: 4rem 0;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <p style="color: var(--color-muted); max-width: 600px; margin: 0 auto; font-size: 1.05rem;">
          Unser Menu vereint traditionelle italienische Rezepte mit frischen Zutaten. Von der Holzofen-Pizza bis zur hausgemachten Pasta – jedes Gericht wird mit Leidenschaft zubereitet.
        </p>
      </div>

      {categories.map((cat) => {
        const items = grouped[cat] || [];
        if (items.length === 0) return null;
        return (
          <div style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.5rem; color: var(--color-accent); border-bottom: 2px solid var(--color-accent); padding-bottom: 0.5rem; margin-bottom: 1.5rem;">
              {categoryLabels[cat] || cat}
            </h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem;">
              {items.map((item) => {
                const img = ITEM_IMAGES[item.slug] || CATEGORY_IMAGES[cat];
                return (
                <div style="background: #fff; border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; transition: box-shadow 0.2s;">
                  {img && <div style="aspect-ratio: 16/9; overflow: hidden;"><img src={img} alt={item.data.title} loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" /></div>}
                  <div style="padding: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                      <h3 style="font-size: 1.1rem; color: var(--color-accent); margin: 0;">{item.data.title}</h3>
                      {item.data.price && <span style="font-weight: 700; color: var(--color-dark); white-space: nowrap; font-size: 1.05rem;">{item.data.price}</span>}
                    </div>
                    {item.data.description && <p style="color: var(--color-muted); font-size: 0.9rem; margin-top: 0.5rem;">{item.data.description}</p>}
                  </div>
                </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Base>
