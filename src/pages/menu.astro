---
import { getDinewayCollection } from "dineway";
import Base from "../layouts/Base.astro";

const { entries: menuItems, cacheHint } = await getDinewayCollection("menu", {
  status: "published",
});
Astro.cache.set(cacheHint);

const categories = ["Antipasti", "Insalate", "Primi Piatti", "Pizza", "Secondi Piatti", "Dessert"];
const categoryLabels = {
  Antipasti: "Antipasti",
  Insalate: "Insalate",
  "Primi Piatti": "Primi Piatti",
  Pizza: "Pizza",
  "Secondi Piatti": "Secondi Piatti",
  Dessert: "Dessert",
};

const grouped = {};
for (const cat of categories) {
  grouped[cat] = menuItems.filter((item) => item.data?.category === cat);
}
---

<Base title="Menu – Ristorante Leonardo da Vinci Hinterzarten" description="Browse our authentic Italian menu at Ristorante Leonardo da Vinci in Hinterzarten. Wood-fired pizza, homemade pasta, fresh salads, and grilled specialties.">
  <div class="page-header">
    <div class="container">
      <h1>Unsere Speisekarte</h1>
      <p>Authentische italienische Küche im Schwarzwald</p>
    </div>
  </div>

  <section style="padding: 4rem 0;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <p style="color: var(--color-muted); max-width: 600px; margin: 0 auto; font-size: 1.05rem;">
          Unser Menu vereint traditionelle italienische Rezepte mit frischen Zutaten. Von der Holzofen-Pizza bis zur hausgemachten Pasta – jedes Gericht wird mit Leidenschaft zubereitet.
        </p>
      </div>

      {categories.map((cat) => {
        const items = grouped[cat] || [];
        if (items.length === 0) return null;
        return (
          <div style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.5rem; color: var(--color-accent); border-bottom: 2px solid var(--color-accent); padding-bottom: 0.5rem; margin-bottom: 1.5rem;">
              {categoryLabels[cat] || cat}
            </h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem;">
              {items.map((item) => (
                <div style="background: #fff; border: 1px solid var(--color-border); border-radius: 8px; padding: 1.25rem; transition: box-shadow 0.2s;">
                  <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                    <h3 style="font-size: 1.1rem; color: var(--color-accent); margin: 0;">{item.data.title}</h3>
                    {item.data.price && <span style="font-weight: 700; color: var(--color-dark); white-space: nowrap; font-size: 1.05rem;">{item.data.price}</span>}
                  </div>
                  {item.data.description && <p style="color: var(--color-muted); font-size: 0.9rem; margin-top: 0.5rem;">{item.data.description}</p>}
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Base>
